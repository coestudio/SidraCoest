<%
  # Renders a checkbox grid for all account features.
  # SuperAdmin::AccountFeaturesHelper (MIT) provides filtered_features.
  all_features = SuperAdmin::AccountFeaturesHelper.filtered_features(field.data)
%>
<div class="field-unit__label">
  <%= f.label field.attribute %>
</div>
<div class="field-unit__field">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% all_features.each do |(feature_key, display_name), enabled| %>
      <label class="flex items-center justify-between p-3 bg-white rounded-lg shadow-sm outline outline-1 outline-n-container cursor-pointer">
        <span class="text-sm text-slate-700"><%= display_name %></span>
        <%= check_box "enabled_features", "feature_#{feature_key}",
              { checked: enabled, class: "h-4 w-4 rounded border-slate-300 text-violet-600 focus:ring-violet-600" },
              true, false %>
      </label>
    <% end %>
  </div>
</div>
